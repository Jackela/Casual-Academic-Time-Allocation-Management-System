#!/usr/bin/env bash
# Enforce local CI parity before any push.
# Emergency bypass (not recommended): SKIP_PRE_PUSH=1 git push ...

set -euo pipefail

if [[ "${SKIP_PRE_PUSH:-0}" == "1" ]]; then
  echo "[pre-push] SKIP_PRE_PUSH=1 detected, skipping checks."
  exit 0
fi

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

echo "========================================="
echo "[pre-push] Running local CI parity checks"
echo "========================================="
echo ""

echo "[1/6] Repository hygiene gate"
bash tools/ci/check-repo-hygiene.sh
echo ""

echo "[2/6] Dependency security audit (high/critical block)"
bash tools/ci/run-security-audit.sh
echo ""

echo "[3/6] Backend checks (gradle check)"
bash tools/ci/run-backend.sh
echo ""

echo "[prep] Ensure frontend lint deps"
if [[ ! -f frontend/node_modules/.bin/eslint && ! -f frontend/node_modules/.bin/eslint.cmd ]]; then
  npm --prefix frontend install --no-audit --no-fund
fi
echo ""

echo "[4/6] Frontend lint"
npm --prefix frontend run lint
echo ""

echo "[5/6] Frontend unit tests (full suite)"
bash tools/ci/run-frontend-unit.sh
echo ""

echo "[6/6] E2E (CI parity: real project)"
if docker info >/dev/null 2>&1; then
  E2E_BACKEND_MODE=docker bash tools/ci/run-e2e.sh
else
  echo "[pre-push] Docker unavailable, fallback to local backend mode for E2E."
  E2E_BACKEND_MODE=local bash tools/ci/run-e2e.sh
fi
echo ""

echo "========================================="
echo "[pre-push] All local CI checks passed."
echo "========================================="
